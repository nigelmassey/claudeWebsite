@page "{id}"
@model claudeWebsite.Pages.Albums.DetailModel
@{
    ViewData["Title"] = Model.Album?.Name ?? "Album";
}

<div class="albums-header">
    <div class="albums-header-left">
        <a class="back-link" asp-page="/Albums/Index">&#x2190; Albums</a>
        <h2 class="page-title" style="margin-bottom:0">@Model.Album!.Name</h2>
    </div>
    <a class="btn-ghost" asp-page="/Albums/Edit" asp-route-id="@Model.Album.Id">Edit</a>
</div>

@if (!Model.Photos.Any())
{
    <p class="gallery-empty">No photos in this album yet. <a asp-page="/Albums/Edit" asp-route-id="@Model.Album.Id">Add some!</a></p>
}
else
{
    <div class="gallery-grid">
    @foreach (var photo in Model.Photos)
    {
        <div class="thumb-wrap" data-fullsrc="/photos/original/@photo.Filename">
            <img class="thumb"
                 src="/photos/thumb/@photo.Filename"
                 width="300" height="300"
                 alt="@photo.UploadedAt.ToString("yyyy-MM-dd HH:mm")" />
            <div class="thumb-caption">
                <span class="thumb-date">@photo.UploadedAt.ToString("yyyy-MM-dd")</span>
            </div>
        </div>
    }
    </div>
}

<div id="lightbox" style="display:none">
    <button id="lb-close" aria-label="Close">&#x2715;</button>
    <img id="lb-img" src="" alt="" />
</div>

@section Scripts {
<script src="~/js/lightbox.js"></script>
}
