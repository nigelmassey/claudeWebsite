@page
@model claudeWebsite.Pages.LoginModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login – Photo Gallery</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garant:ital,wght@0,400;1,400;1,600&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&display=swap" rel="stylesheet" />
    <style>
        *, *::before, *::after { box-sizing: border-box; }
        body {
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            margin: 0;
            font-family: 'DM Sans', system-ui, sans-serif;
            background: #0c0b09;
            color: #f0ebe3;
            -webkit-font-smoothing: antialiased;
        }
        .login-card {
            display: flex;
            flex-direction: column;
            gap: 1rem;
            background: #141210;
            border: 1px solid #2a2620;
            padding: 2.5rem 2.25rem;
            border-radius: 10px;
            min-width: 300px;
            width: 100%;
            max-width: 340px;
        }
        .login-brand {
            font-family: 'Cormorant Garant', Georgia, serif;
            font-size: 1.8rem;
            font-weight: 400;
            font-style: italic;
            color: #f0ebe3;
            margin: 0 0 0.75rem;
            letter-spacing: 0.01em;
        }
        input[type=password] {
            font-family: 'DM Sans', system-ui, sans-serif;
            font-size: 0.9375rem;
            padding: 0.625rem 0.875rem;
            border-radius: 4px;
            border: 1px solid #3a352e;
            background: #1c1a17;
            color: #f0ebe3;
            width: 100%;
            outline: none;
            transition: border-color 180ms ease;
        }
        input[type=password]:focus { border-color: #9c7d4c; }
        input[type=password]::placeholder { color: #524c44; }
        button {
            font-family: 'DM Sans', system-ui, sans-serif;
            font-size: 0.78rem;
            font-weight: 500;
            letter-spacing: 0.09em;
            text-transform: uppercase;
            padding: 0.65rem 1.5rem;
            background: #c8a46a;
            color: #1a1208;
            border: none;
            border-radius: 3px;
            cursor: pointer;
            transition: background 180ms ease, transform 180ms ease;
        }
        button:hover { background: #d4b47c; transform: translateY(-1px); }
        button:active { transform: translateY(0); }
        .error {
            font-size: 0.82rem;
            color: #d97070;
            padding: 0.5rem 0.75rem;
            background: rgba(217,112,112,0.07);
            border: 1px solid rgba(217,112,112,0.18);
            border-radius: 3px;
            margin: 0;
        }
    </style>
</head>
<body>
    <form class="login-card" method="post">
        <h1 class="login-brand">Photo Gallery</h1>
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <p class="error">@Model.ErrorMessage</p>
        }
        <input type="password" name="Password" placeholder="Password" autofocus />
        <button type="submit">Sign in</button>
    </form>
</body>
</html>
