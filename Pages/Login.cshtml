@page
@model claudeWebsite.Pages.LoginModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login – Photo Gallery</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&display=swap" rel="stylesheet" />
    <script type="importmap">
    {
        "imports": {
            "@@material/web/": "https://esm.run/@@material/web@@2.1.0/"
        }
    }
    </script>
    <script type="module">
        import '@@material/web/textfield/outlined-text-field.js';
        import '@@material/web/button/filled-button.js';
    </script>
    <style>
        *, *::before, *::after { box-sizing: border-box; }

        :root {
            --md-sys-color-primary:              #7B5800;
            --md-sys-color-on-primary:           #FFFFFF;
            --md-sys-color-primary-container:    #FFDF9F;
            --md-sys-color-error:                #BA1A1A;
            --md-sys-color-error-container:      #FFDAD6;
            --md-sys-color-background:           #FFF8F2;
            --md-sys-color-on-background:        #1F1B16;
            --md-sys-color-surface-container-low:#FCF2E7;
            --md-sys-color-outline-variant:      #D3C4B0;
            --md-sys-color-outline:              #817566;
            --md-sys-color-on-surface:           #1F1B16;
            --md-sys-color-on-surface-variant:   #4F4539;
            --md-sys-shape-corner-extra-small:   4px;
            --md-sys-shape-corner-small:         8px;
            --md-sys-shape-corner-medium:        12px;
            --md-sys-shape-corner-full:          9999px;
        }

        body {
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            margin: 0;
            font-family: 'Roboto', system-ui, sans-serif;
            background: var(--md-sys-color-background);
            color: var(--md-sys-color-on-background);
            -webkit-font-smoothing: antialiased;
        }

        .login-card {
            display: flex;
            flex-direction: column;
            gap: 1.25rem;
            background: var(--md-sys-color-surface-container-low);
            border: 1px solid var(--md-sys-color-outline-variant);
            padding: 2.5rem 2.25rem;
            border-radius: var(--md-sys-shape-corner-medium);
            min-width: 300px;
            width: 100%;
            max-width: 360px;
        }

        .login-brand {
            font-family: 'Roboto', system-ui, sans-serif;
            font-size: 1.5rem;
            font-weight: 400;
            color: var(--md-sys-color-on-surface);
            margin: 0 0 0.5rem;
            letter-spacing: 0;
        }

        .error {
            font-size: 0.85rem;
            color: var(--md-sys-color-error);
            padding: 0.5rem 0.75rem;
            background: var(--md-sys-color-error-container);
            border: 1px solid color-mix(in srgb, var(--md-sys-color-error) 30%, transparent);
            border-radius: var(--md-sys-shape-corner-extra-small);
            margin: 0;
        }

        md-outlined-text-field { width: 100%; }
        md-filled-button { width: 100%; }
    </style>
</head>
<body>
    <form class="login-card" method="post">
        <h1 class="login-brand">Photo Gallery</h1>
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <p class="error">@Model.ErrorMessage</p>
        }
        <md-outlined-text-field
            type="password"
            name="Password"
            label="Password"
            autofocus>
        </md-outlined-text-field>
        <md-filled-button type="submit">Sign in</md-filled-button>
    </form>
</body>
</html>
