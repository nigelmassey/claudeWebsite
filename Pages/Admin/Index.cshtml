@page
@model claudeWebsite.Pages.Admin.IndexModel
@{
    ViewData["Title"] = "Admin";
}

@section Scripts {
<script type="module">
    import '@@material/web/button/filled-button.js';
    import '@@material/web/button/outlined-button.js';
    import '@@material/web/button/text-button.js';
</script>
}

<h1 class="page-title">Admin Portal</h1>

<div class="admin-section">
    <h2>Actions</h2>
    <div class="admin-actions">
        <md-filled-button onclick="location.href='@Url.Page("/Upload")'">Upload Photos</md-filled-button>
        <md-outlined-button onclick="location.href='@Url.Page("/Albums/Create")'">Create Album</md-outlined-button>
    </div>
</div>

<div class="admin-section">
    <h2>Photos (@Model.Photos.Count)</h2>
    @if (!Model.Photos.Any())
    {
        <p class="gallery-empty" style="margin-top:1rem">No photos uploaded yet.</p>
    }
    else
    {
        <table class="admin-table">
            <thead>
                <tr>
                    <th>Thumbnail</th>
                    <th>Filename</th>
                    <th>Uploaded</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var photo in Model.Photos)
                {
                    <tr>
                        <td><img src="/photos/thumb/@photo.Filename" style="width:60px;height:60px;object-fit:cover;border-radius:4px;" /></td>
                        <td>@photo.Filename</td>
                        <td>@photo.UploadedAt.ToString("yyyy-MM-dd HH:mm")</td>
                        <td>
                            <form method="post">
                                <input type="hidden" name="filename" value="@photo.Filename" />
                                <md-text-button class="error-btn" type="submit" asp-page-handler="DeletePhoto"
                                        onclick="return confirm('Delete @photo.Filename?')">Delete</md-text-button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

<div class="admin-section">
    <h2>Albums (@Model.Albums.Count)</h2>
    @if (!Model.Albums.Any())
    {
        <p class="gallery-empty" style="margin-top:1rem">No albums yet.</p>
    }
    else
    {
        <table class="admin-table">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Photos</th>
                    <th>Created</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var album in Model.Albums)
                {
                    <tr>
                        <td>@album.Name</td>
                        <td>@album.PhotoFilenames.Count</td>
                        <td>@album.CreatedAt.ToString("yyyy-MM-dd")</td>
                        <td style="display:flex;align-items:center;gap:0.25rem">
                            <md-outlined-button onclick="location.href='@Url.Page("/Albums/Edit", new { id = album.Id })'">Edit</md-outlined-button>
                            <form method="post" style="display:inline">
                                <input type="hidden" name="id" value="@album.Id" />
                                <md-text-button class="error-btn" type="submit" asp-page-handler="DeleteAlbum"
                                        onclick="return confirm('Delete album @album.Name?')">Delete</md-text-button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
