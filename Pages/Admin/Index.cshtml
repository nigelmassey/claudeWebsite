@page
@model claudeWebsite.Pages.Admin.IndexModel
@{
    ViewData["Title"] = "Admin";
}

<h1>Admin Portal</h1>

<section>
    <h2>Actions</h2>
    <a asp-page="/Upload">Upload Photos</a>
    &nbsp;|&nbsp;
    <a asp-page="/Albums/Create">Create Album</a>
</section>

<section>
    <h2>Photos (@Model.Photos.Count)</h2>
    @if (!Model.Photos.Any())
    {
        <p>No photos uploaded yet.</p>
    }
    else
    {
        <table>
            <thead>
                <tr>
                    <th>Thumbnail</th>
                    <th>Filename</th>
                    <th>Uploaded</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var photo in Model.Photos)
                {
                    <tr>
                        <td><img src="/photos/thumb/@photo.Filename" style="width:60px;height:60px;object-fit:cover;" /></td>
                        <td>@photo.Filename</td>
                        <td>@photo.UploadedAt.ToString("yyyy-MM-dd HH:mm")</td>
                        <td>
                            <form method="post">
                                <input type="hidden" name="filename" value="@photo.Filename" />
                                <button type="submit" asp-page-handler="DeletePhoto"
                                        onclick="return confirm('Delete @photo.Filename?')">Delete</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</section>

<section>
    <h2>Albums (@Model.Albums.Count)</h2>
    @if (!Model.Albums.Any())
    {
        <p>No albums yet.</p>
    }
    else
    {
        <table>
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Photos</th>
                    <th>Created</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var album in Model.Albums)
                {
                    <tr>
                        <td>@album.Name</td>
                        <td>@album.PhotoFilenames.Count</td>
                        <td>@album.CreatedAt.ToString("yyyy-MM-dd")</td>
                        <td>
                            <a asp-page="/Albums/Edit" asp-route-id="@album.Id">Edit</a>
                            &nbsp;
                            <form method="post" style="display:inline">
                                <input type="hidden" name="id" value="@album.Id" />
                                <button type="submit" asp-page-handler="DeleteAlbum"
                                        onclick="return confirm('Delete album @album.Name?')">Delete</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</section>
