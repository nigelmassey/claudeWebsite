@page
@model claudeWebsite.Pages.PhotosModel
@{
    ViewData["Title"] = "Gallery";
}

<div class="gallery-grid">
@foreach (var photo in Model.Photos)
{
    <div class="thumb-wrap" data-fullsrc="/photos/original/@photo.Filename">
        <img class="thumb"
             src="/photos/thumb/@photo.Filename"
             width="300" height="300"
             alt="@photo.UploadedAt.ToString("yyyy-MM-dd HH:mm")" />
        <div class="thumb-caption">
            <span class="thumb-date">@photo.UploadedAt.ToString("yyyy-MM-dd")</span>
        </div>
    </div>
}
</div>

@if (!Model.Photos.Any())
{
    <p class="gallery-empty">No photos yet. <a href="/Upload">Upload one!</a></p>
}

<div id="lightbox" style="display:none">
    <button id="lb-close" aria-label="Close">&#x2715;</button>
    <img id="lb-img" src="" alt="" />
</div>

@section Scripts {
<script src="~/js/lightbox.js"></script>
}
